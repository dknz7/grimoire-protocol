{
  "_comment": "Merge this into your existing settings file. If you already have permissions or hooks, add these entries — don't overwrite.",
  "_comment_paths": "IMPORTANT: Replace the hook commands below with ABSOLUTE paths to your vault's scripts. On Windows, Claude Code runs hooks through bash (Git Bash), NOT PowerShell — use forward slashes: /c/Users/you/vault/scripts/grimoire/session-start.py, NOT backslashes.",

  "permissions": {
    "allow": [
      "mcp__grimoire__wiki_status",
      "mcp__grimoire__wiki_search",
      "mcp__grimoire__wiki_read",
      "mcp__grimoire__wiki_list",
      "mcp__grimoire__wiki_write_summary",
      "mcp__grimoire__wiki_write_article",
      "mcp__grimoire__wiki_add_ontology",
      "mcp__grimoire__wiki_add_source",
      "mcp__grimoire__wiki_learn",
      "mcp__grimoire__wiki_commit",
      "mcp__grimoire__wiki_compile_diff",
      "mcp__grimoire__wiki_ontology_query",
      "mcp__grimoire__wiki_lint"
    ]
  },

  "hooks": {
    "SessionStart": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "python3 scripts/grimoire/session-start.py",
        "timeout": 15
      }]
    }],
    "PreCompact": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "python3 scripts/grimoire/pre-compact.py",
        "timeout": 10
      }]
    }],
    "SessionEnd": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "python3 scripts/grimoire/session-end.py",
        "timeout": 10
      }]
    }]
  }
}
