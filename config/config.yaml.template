# Grimoire Protocol — sage-wiki configuration
#
# Copy this to your vault root as 'config.yaml' and customise.
# The grimoire engine (sage-wiki) reads this on startup.
#
# IMPORTANT: The api/models sections use dummy values — all LLM work
# runs through your Claude Code subscription, not sage-wiki's built-in
# API calls. Never call wiki_compile or wiki_capture MCP tools.

version: 1
# Name your vault — this shows as "Vault:" in /grimoire status
project: my-vault
description: "My compiled knowledge base"

sources:
  - path: inbox/sessions
    type: auto
    watch: true
  - path: inbox/tldr
    type: auto
    watch: true
  - path: inbox/daily
    type: auto
    watch: true
  - path: inbox/drops
    type: auto
    watch: true
  - path: inbox/skills      # Populated by scripts/grimoire/snapshot-skills.py — captures your active assistant skills
    type: auto
    watch: true
  - path: daily
    type: auto
    watch: true
  # Add your own source folders below.
  # Set watch: true for folders that change frequently.
  # Set watch: false for folders you compile manually.
  # - path: projects
  #   type: auto
  #   watch: false
  # - path: research
  #   type: auto
  #   watch: false

output: wiki

# IGNORE NOTES (engine quirks — verified empirically):
#   - Bare names in ignore match TOP-LEVEL ONLY. Engine does NOT support "**/" recursive globs.
#   - File-extension globs (e.g. "*.psd", "*.gitkeep") DO NOT WORK — they are silently
#     ignored. Filter binaries in the nightly routine's registration step instead.
#   - For NESTED paths, you must list both slash forms — the Windows engine reports paths
#     with backslashes, *nix with forward. Example for a nested git dir:
#       - "templates/prompt-templates/.git"
#       - "templates\\prompt-templates\\.git"
#   - Every time you clone a new repo into the vault, add its .git path here in BOTH forms.
ignore:
  - .obsidian
  - .git
  - .claude
  - .sage
  - .grimoire
  - archive
  - node_modules
  # Add your own ignore patterns. Examples:
  # - tools                  # tool / binary directories that aren't knowledge sources
  # - "resources/mcps"       # third-party clones — both slash forms on Windows
  # - "resources\\mcps"
  # - "templates/prompt-templates/.git"
  # - "templates\\prompt-templates\\.git"

# Dummy API config — passes engine validation but is never used.
# All LLM work runs through Claude Code subscription.
api:
  provider: anthropic
  api_key: "not-used-subscription-powered"

models:
  summarize: "not-used"
  extract: "not-used"
  write: "not-used"
  lint: "not-used"
  query: "not-used"

compiler:
  max_parallel: 1
  auto_commit: false
  auto_lint: false
  # Set your IANA timezone:
  timezone: Australia/Sydney

search:
  hybrid_weight_bm25: 0.7
  hybrid_weight_vector: 0.3
  default_limit: 10

serve:
  transport: stdio
